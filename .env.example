# ═══════════════════════════════════════════════
#  PastryStock Manager — Variables de Entorno
#  Copiar como .env y ajustar valores antes de
#  ejecutar docker-compose up
# ═══════════════════════════════════════════════

# ── PostgreSQL ──────────────────────────────────
POSTGRES_USER=pastry_user
POSTGRES_PASSWORD=pastry_secret_2024
POSTGRES_DB=pastry_inventory

# ── Redis ───────────────────────────────────────
REDIS_PASSWORD=redis_secret_2024
REDIS_CACHE_TTL=3600

# ── Seguridad JWT ───────────────────────────────
# Generar con: openssl rand -hex 32
SECRET_KEY=REEMPLAZAR_CON_VALOR_GENERADO_POR_OPENSSL
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Seed Superadministrador ─────────────────────
SUPERADMIN_EMAIL=superadmin@mipasteleria.pe
SUPERADMIN_PASSWORD=Sup3r@Admin2024!

# ── NextAuth ────────────────────────────────────
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=REEMPLAZAR_CON_VALOR_GENERADO_POR_OPENSSL
